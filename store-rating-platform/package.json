{
  "name": "store-rating-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c green,cyan \"npm run dev -w server\" \"npm run dev -w client\"",
    "server": "npm run dev -w server",
    "client": "npm run dev -w client",
    "migrate": "npm run migrate -w server",
    "seed": "npm run seed -w server",
    "build": "npm run build -w client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
